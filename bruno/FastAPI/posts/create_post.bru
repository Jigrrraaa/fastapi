meta {
  name: Create Post
  type: http
  seq: 5
}

post {
  url: http://127.0.0.1:8000/posts
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "title": "My First Post",
    "content": "This is the content of my post",
    "published": true
  }
}

docs {
  Create a new post.
  Requires Bearer token from login.
  Use {{token}} variable - set it in environment.
}
